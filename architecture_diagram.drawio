        <mxCell id="legend-tech" value="&lt;b&gt;TECH STACK:&lt;/b&gt;&lt;br&gt;🌐 Frontend: HTML5 + CSS3 + Vanilla JS&lt;br&gt;🔧 API Gateway: PHP 7.4+ (XAMPP)&lt;br&gt;🤖 AI Engine: Python 3.8+ (FastAPI)&lt;br&gt;🧠 LLM: Google Gemini 1.5 Pro&lt;br&gt;📊 Vector DB: FAISS (HuggingFace)&lt;br&gt;🗄️ Database: MySQL 8.0+&lt;br&gt;🔗 Framework: LangChain 0.1.0" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1100" y="260" width="420" height="110" as="geometry" />
        </mxCell>

        <!-- ========== PROCESS FLOW ========== -->
        <mxCell id="process-flow" value="PROCESS FLOW (RAG Pipeline)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="1080" y="420" width="480" height="260" as="geometry" />
        </mxCell>
        
        <mxCell id="flow-text" value="&lt;b&gt;1. USER INPUT&lt;/b&gt;&lt;br&gt;   User gửi câu hỏi qua Browser → PHP chat.php&lt;br&gt;&lt;br&gt;&lt;b&gt;2. API GATEWAY&lt;/b&gt;&lt;br&gt;   PHP proxy request → FastAPI port 8001&lt;br&gt;&lt;br&gt;&lt;b&gt;3. EMBEDDING&lt;/b&gt;&lt;br&gt;   HuggingFace model chuyển query thành vector&lt;br&gt;&lt;br&gt;&lt;b&gt;4. RETRIEVAL&lt;/b&gt;&lt;br&gt;   FAISS tìm 5 documents tương tự (cosine)&lt;br&gt;&lt;br&gt;&lt;b&gt;5. GENERATION&lt;/b&gt;&lt;br&gt;   LangChain + Gemini tạo câu trả lời&lt;br&gt;&lt;br&gt;&lt;b&gt;6. POST-PROCESSING&lt;/b&gt;&lt;br&gt;   Markdown → HTML (food cards + tips)&lt;br&gt;&lt;br&gt;&lt;b&gt;7. RESPONSE&lt;/b&gt;&lt;br&gt;   PHP lưu MySQL → Trả về Browser → Render UI" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="1100" y="460" width="440" height="210" as="geometry" />
        </mxCell>

        <!-- ========== KEY FEATURES ========== -->
        <mxCell id="features" value="KEY FEATURES" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="1080" y="720" width="480" height="200" as="geometry" />
        </mxCell>
        
        <mxCell id="features-text" value="✅ &lt;b&gt;No Chunking Strategy&lt;/b&gt;: Mỗi dòng CSV = 1 document&lt;br&gt;✅ &lt;b&gt;Fine-tuned Embeddings&lt;/b&gt;: Vietnamese food domain&lt;br&gt;✅ &lt;b&gt;Semantic Search&lt;/b&gt;: FAISS cosine similarity (k=5)&lt;br&gt;✅ &lt;b&gt;Low Temperature&lt;/b&gt;: 0.3 cho factual responses&lt;br&gt;✅ &lt;b&gt;Structured Output&lt;/b&gt;: Food cards + Tips section&lt;br&gt;✅ &lt;b&gt;HTML Persistence&lt;/b&gt;: Lưu response_html vào DB&lt;br&gt;✅ &lt;b&gt;Session Auth&lt;/b&gt;: PHP session-based security&lt;br&gt;✅ &lt;b&gt;Blue Theme UI&lt;/b&gt;: Custom CSS với #005f8d&lt;br&gt;✅ &lt;b&gt;Fallback Mechanism&lt;/b&gt;: Auto-generate tips nếu thiếu" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacingLeft=20;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="760" width="440" height="150" as="geometry" />
        </mxCell>

